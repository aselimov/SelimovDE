#!/bin/bash
# This files is an adjusted version of:
# https://github.com/porras/dmenu-emoji
#
# If this file includes emojis below "__DATA__" it is generated.
# This file was generated: 2022-04-21 12:38:03+00:00

set -e

dmenu="dmenu -theme-str 'window {width: 50%;}'  -i -p Emoji"
case "$1" in
  "list")
    data=$(sed '0,/^__DATA__$/d' "$0")
    echo "$data"
    ;;
  "copy")
    input=$(tee)
    if [ ! -z "$input" ]; then
      emoji=${input: -1}
      xdotool type "$emoji" 
    fi
    ;;
  "")
    bash $0 list | eval "$dmenu" | bash $0 copy
    ;;
esac

exit

